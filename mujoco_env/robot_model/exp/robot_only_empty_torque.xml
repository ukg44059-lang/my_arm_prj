<?xml version="1.0" ?>
<mujoco model="robot_arm620_robotiq_empty_torque">
    <compiler angle="radian" meshdir="../robot/meshes/" />
    <size njmax="500" nconmax="100" />

    <option cone="elliptic" impratio="10" viscosity="0.1" timestep="0.001" iterations="150" solver="Newton" tolerance="1e-10">
        <flag contact="enable" override="enable"/>
    </option>

    <visual>
        <global offwidth="1280" offheight="720"/>
    </visual>

    <!-- 쐐痰샙筠글寮狼菱툭旒 -->
    <contact>
        <exclude body1="base" body2="Link1"/>
        <exclude body1="base" body2="Link2"/>
        <exclude body1="base" body2="Link3"/>
        <exclude body1="base" body2="Link4"/>
        <exclude body1="base" body2="Link5"/>
        <exclude body1="base" body2="Link6"/>
        <exclude body1="Link1" body2="Link2"/>
        <exclude body1="Link1" body2="Link3"/>
        <exclude body1="Link2" body2="Link3"/>
        <exclude body1="Link2" body2="Link4"/>
        <exclude body1="Link3" body2="Link4"/>
        <exclude body1="Link3" body2="Link5"/>
        <exclude body1="Link4" body2="Link5"/>
        <exclude body1="Link4" body2="Link6"/>
        <exclude body1="Link5" body2="Link6"/>
    </contact>

    <!-- 쏭괏즛샙포훙宅셸屢杰矜栗都 -->
