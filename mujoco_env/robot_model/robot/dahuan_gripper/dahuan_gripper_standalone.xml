<mujoco model="dahuan_gripper_standalone">
    <compiler angle="radian" meshdir="../meshes/"/>
    <option timestep="0.002"/>

    <visual>
        <global offwidth="1280" offheight="720"/>
    </visual>

    <asset>
        <!-- 夹爪网格文件 -->
        <mesh name="dahuan-gripper-base"  file="dahuan_gripper/gripper_link.STL"   />
        <mesh name="dahuan-finger1"       file="dahuan_gripper/finger1_Link.STL"   />
        <mesh name="dahuan-finger2"       file="dahuan_gripper/finger2_Link.STL"   />

        <!-- 材质 -->
        <texture type="skybox" builtin="gradient" rgb1="0.3 0.5 0.7" rgb2="0 0 0" width="512" height="3072"/>
        <texture type="2d" name="groundplane" builtin="checker" mark="edge" rgb1="0.2 0.3 0.4" rgb2="0.1 0.2 0.3" markrgb="0.8 0.8 0.8" width="300" height="300"/>
        <material name="groundplane" texture="groundplane" texuniform="true" texrepeat="5 5" reflectance="0.2"/>
    </asset>

    <default>
        <default class="dahuangripper">
            <joint damping="10" pos="0 0 0" axis="1 0 0" limited="true" type="slide"/>
            <geom rgba=".8 .8 .8 1" type="mesh" contype="0" conaffinity="0" group="1"/>
            <default class="dahuan_col">
                <geom rgba=".5 .5 .5 1" type="mesh" contype="0" conaffinity="0" group="3"/>
            </default>
            <default class="dahuan_pad_col">
                <geom rgba=".3 .3 .3 1" type="box" contype="1" conaffinity="1" group="3" condim="4" friction="1.0 0.005 0.0001"/>
            </default>
        </default>
    </default>

    <sensor>
        <jointpos name="dahuan_gripper_sensor" joint="dahuan_finger1_joint"/>
    </sensor>

    <!-- Two fingers mimic each other -->
    <equality>
        <joint joint1="dahuan_finger1_joint" joint2="dahuan_finger2_joint"/>
    </equality>

    <!-- Actuator -->
    <actuator>
        <position name="dahuan_gripper" joint="dahuan_finger1_joint" ctrlrange="0 0.025" ctrllimited="true" kp="100"/>
    </actuator>

    <worldbody>
        <!-- 光照 -->
        <light directional="true" diffuse="0.8 0.8 0.8" specular="0.2 0.2 0.2" pos="0 0 4" dir="0 0 -1"/>
        <light directional="true" diffuse="0.4 0.4 0.4" specular="0.1 0.1 0.1" pos="0 0 5" dir="0 0 -1"/>

        <!-- 地板 -->
        <geom name="floor" size="1 1 0.1" type="plane" material="groundplane"/>

        <!-- 夹爪模型 - 固定在空中以便观察 -->
        <body name="gripper_mount" pos="0 0 0.3">
            <inertial pos="0 0 0" mass="0.01" diaginertia="0.0001 0.0001 0.0001"/>

            <body name="dahuan_gripper" pos="0 0 0" childclass="dahuangripper">
                <!-- Gripper base link -->
                <inertial pos="-3.9257E-06 -0.00027208 0.0435" mass="1.0"
                          fullinertia="0.00036805 0.0003341 0.00022294 -7.2868E-08 -5.0168E-08 -2.6462E-06" />
                <geom mesh="dahuan-gripper-base" />
                <geom class="dahuan_col" type="mesh" mesh="dahuan-gripper-base"/>

                <!-- Finger 1 (right side) -->
                <body name="dahuan_finger1" pos="0.0132 0.0265 0.093" euler="0 0 -1.5708">
                    <inertial pos="0.0030491 -0.0066024 0.0064209" mass="0.014278"
                              fullinertia="1.7567E-06 2.3034E-06 1.3354E-06 -5.7832E-08 2.6803E-08 2.2145E-07" />
                    <joint name="dahuan_finger1_joint" range="0 0.025" />
                    <geom mesh="dahuan-finger1" />
                    <geom class="dahuan_col" type="mesh" mesh="dahuan-finger1" />
                    <!-- Collision pad for grasping -->
                    <geom class="dahuan_pad_col" type="box" size=".001 .008 .009" pos="0.0005 -0.013 0.03"/>
                </body>

                <!-- Finger 2 (left side) -->
                <body name="dahuan_finger2" pos="-0.0132 -0.0265 0.093" euler="0 0 1.5708">
                    <inertial pos="0.0030491 -0.0066024 0.0064209" mass="0.014278"
                              fullinertia="1.7567E-06 2.3034E-06 1.3354E-06 -5.7832E-08 2.6803E-08 2.2145E-07" />
                    <joint name="dahuan_finger2_joint" range="0 0.025" />
                    <geom mesh="dahuan-finger2" />
                    <geom class="dahuan_col" type="mesh" mesh="dahuan-finger2" />
                    <!-- Collision pad for grasping -->
                    <geom class="dahuan_pad_col" type="box" size=".001 .008 .009" pos="0.0005 -0.013 0.03"/>
                </body>
            </body>
        </body>
    </worldbody>
</mujoco>
